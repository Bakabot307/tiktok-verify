{
  "headers": [
    {
      "source": "/(.*).txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/((?!.*\\.txt$).*)",
      "destination": "http://localhost:4200/$1",
      "permanent": false
    }
  ]
}
